# TheHopper mobile app environment configuration
# Copy this file to `.env` and adjust values for your setup.
#
# Development: point to your locally-running FastAPI backend.
#   Start backend with: cd backend && source venv/bin/activate && uvicorn main:app --reload
#   On a physical device, use your computer's LAN IP instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Production: set this to your deployed backend URL.
# EXPO_PUBLIC_API_URL=https://api.launchable.co/api
