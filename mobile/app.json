{
  "expo": {
    "name": "TheHopper",
    "slug": "thehopper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "thehopper",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.launchable.thehopper",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TheHopper uses your location to find karaoke venues near you."
      }
    },
    "android": {
      "package": "co.launchable.thehopper",
      "adaptiveIcon": {
        "backgroundColor": "#0d0221",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Show karaoke venues near you."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ff2d95"
        }
      ]
    ],
    "experiments": {
      "tscPaths": true
    },
    "extra": {
      "EXPO_PUBLIC_API_URL": "https://thehopper-api.alchemycreativelounge.com/api",
      "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_51S0HoNPqi0Pe8qbKcTaUKGgsIL3T1EhFSNHWJDZ8tyyiZi6ZfxgIuIu2X6pMzgKWIuToo3wNwm3rqYtagiVdx1XA00oCM0bedf"
    }
  }
}
